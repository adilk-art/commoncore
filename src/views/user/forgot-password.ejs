<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Forgot Password</title>
    <link rel="stylesheet" href="/css/user/forgot-password.css">
</head>
<body>

<div class="container">
    <div class="card">
        <h2>Forgot Password</h2>
        <p>Enter your email to receive a password reset link</p>

        <% if (typeof message !== 'undefined') { %>
            <p class="message"><%= message %></p>
        <% } %>

        <form action="/user/forgot-password" method="POST" id="emailForm">
            <div class="input-group">
                <label>Email Address</label>
                <input id="email" type="text" name="email" placeholder="name@example.com"/>
            </div>

            <% if(error) { %>
                <span class="error-msg" id="errorMsg" style="display:block"><%= error %></span>
            <% } else { %>
                <span class="error-msg" id="errorMsg" style="display:none"></span>
            <% } %>

            <button type="submit">Send Reset Link</button>
        </form>

        <a href="/user/login" class="back-link">Back to Login</a>
    </div>
</div>
<script src="/js/user/forgotPassword.js"></script>

</body>
</html>