<!DOCTYPE html>
<html lang="en">
<head>
  <title>Wishlist — Stitch</title>
  <%- include('../partials/user-head') %>
  <link rel="stylesheet" href="/css/user/wishlist.css">
</head>
<body>

<%- include('../partials/user-header') %>

<main class="wishlist-page">

  <section class="wishlist-card card card-lg">

    <div class="wishlist-head">
      <div>
        <h1 class="text-page-title">Wishlist</h1>
        <p class="text-body"><%= items.length %> saved items</p>
      </div>

      <% if(items.length > 0){ %>
        <button class="primary-btn" id="addAllBtn">
          Add All to Cart
        </button>
      <% } %>
    </div>

    <% if(items.length === 0){ %>

      <div class="wishlist-empty">
        <p class="text-body">Your wishlist is empty.</p>
        <a href="/user/shop" class="secondary-btn">
          Continue Shopping
        </a>
      </div>

    <% } else { %>

      <div class="wishlist-grid">

        <% items.forEach(item => { %>

          <article class="wishlist-item">

            <a href="/user/product/<%= item.product._id %>" class="wishlist-image-wrap">

              <img
                src="<%= item.variant?.images?.[0]?.url || '/images/no-image.png' %>"
                class="wishlist-image"
                alt="<%= item.product.name %>"
              >

              <% if(item.unavailable){ %>

  <span class="wishlist-stock-badge">
    Unavailable
  </span>

<% } else if(!item.inStock){ %>

  <span class="wishlist-stock-badge">
    Out of Stock
  </span>

<% } %>

            </a>

            <div class="wishlist-content">

              <div>
                <p class="wishlist-category">
                  <%= item.product.categoryId.name %>
                </p>

                <h3 class="wishlist-name">
                  <%= item.product.name %>
                </h3>

                <p class="wishlist-price">
                  ₹<%= item.variant?.price?.toLocaleString('en-IN') || '--' %>
                </p>
              </div>

              <div class="wishlist-actions">

                <button
                  class="wishlist-cart-btn move-cart"
                  data-id="<%= item.product._id %>"
                  <%= !item.inStock ? 'disabled' : '' %>
                >
                  Move to Cart
                </button>

                <button
                  class="wishlist-remove-btn remove-wishlist"
                  data-id="<%= item.product._id %>"
                >
                  Remove
                </button>

              </div>

            </div>

          </article>

        <% }) %>

      </div>

    <% } %>

  </section>

</main>
<div class="variant-modal" id="variantModal">

  <div class="variant-modal-content">

    <div class="variant-modal-head">
      <h3>Select Variant</h3>

      <button id="closeVariantModal">
        ×
      </button>
    </div>

    <div
      class="variant-modal-error"
      id="variantModalError"
    ></div>

    <div
      class="variant-modal-body"
      id="variantOptions"
    ></div>

    <button
      class="primary-btn"
      id="confirmVariantBtn"
    >
      Add to Cart
    </button>

  </div>

</div>

<%- include('../partials/user-scripts') %>
<script src="/js/user/wishlist.js"></script>

</body>
</html>