<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= product.name %> — Stitch</title>
    <%- include('../partials/user-head') %>
  <link rel="stylesheet" href="/css/user/product-detail.css" />
</head>
<body>

  <%- include('../partials/user-header.ejs') %>

  <main class="pd-page">

    <!-- Breadcrumb -->
    <div class="pd-breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/user/shop">Shop</a>
      <span>/</span>
      <a href="/user/shop?category=<%= product.categoryId._id %>"><%= product.categoryId.name %></a>
      <span>/</span>
      <p><%= product.name %></p>
    </div>

    <!-- MAIN LAYOUT -->
    <section class="pd-layout">

      <!-- THUMBS -->
      <div class="pd-thumbs" id="thumbsCol">
        <% selectedVariant.images.forEach((img, index) => { %>
          <button
            type="button"
            class="pd-thumb <%= index === 0 ? 'pd-thumb--active' : '' %>"
            data-image="<%= img.url %>"
          >
            <img src="<%= img.url %>" alt="" />
          </button>
        <% }) %>
      </div>

      <!-- MAIN IMAGE -->
      <div class="pd-image-box">
        <% if (selectedVariant.stock <= 0) { %>
          <div class="pd-soldout">Sold Out</div>
        <% } %>
        <div class="pd-image-zoom" id="zoomContainer">
          <img
            src="<%= selectedVariant.images[0]?.url %>"
            alt="<%= product.name %>"
            id="mainImage"
            class="pd-main-image"
          />
        </div>
      </div>

      <!-- INFO -->
      <div class="pd-info">

        <!-- Category tag -->
        <p class="pd-category-tag"><%= product.categoryId.name %></p>

        <!-- Title -->
        <h1 class="pd-title"><%= product.name %></h1>

        <!-- Price -->
        <div class="pd-price-wrap">
          <span class="pd-price" id="displayPrice">
            ₹<%= selectedVariant.price.toLocaleString('en-IN') %>
          </span>
          <% if (product.comparePrice && product.comparePrice > selectedVariant.price) { %>
            <span class="pd-old-price">₹<%= product.comparePrice.toLocaleString('en-IN') %></span>
            <span class="pd-discount">
              <%= Math.round(((product.comparePrice - selectedVariant.price) / product.comparePrice) * 100) %>% OFF
            </span>
          <% } %>
        </div>

        <!-- Description -->
        <p class="pd-desc"><%= product.description %></p>

        <!-- Stock -->
        <div class="pd-stock-row" id="stockRow">
          <% if (selectedVariant.stock > 10) { %>
            <span class="pd-stock pd-stock--green">In Stock</span>
          <% } else if (selectedVariant.stock > 0) { %>
            <span class="pd-stock pd-stock--orange">Only <%= selectedVariant.stock %> left</span>
          <% } else { %>
            <span class="pd-stock pd-stock--red">Out of Stock</span>
          <% } %>
        </div>

        <!-- Color -->
        <div class="pd-option">
          <h4 class="pd-label">
            Color: <span id="colorLabel"><%= selectedVariant.color.name %></span>
          </h4>
          <div class="pd-colors">
            <%
                                                       // Group unique colors; map color code → first variant with that color
              const colorMap = {};
              variants.forEach(v => {
                if (!colorMap[v.color.code]) colorMap[v.color.code] = v;
              });
            %>
            <% Object.values(colorMap).forEach(v => { %>
              <button
                type="button"
                class="pd-color <%= v.color.code === selectedVariant.color.code ? 'pd-color--active' : '' %>"
                style="background:<%= v.color.code %>"
                title="<%= v.color.name %>"
                data-color-code="<%= v.color.code %>"
                data-color-name="<%= v.color.name %>"
              ></button>
            <% }) %>
          </div>
        </div>

        <!-- Size -->
        <div class="pd-option">
          <h4 class="pd-label">
            Size: <span id="sizeLabel"><%= selectedVariant.size %></span>
          </h4>
          <div class="pd-sizes" id="sizesWrap">
            <%
              // All variants as JSON for JS
              const variantsJson = JSON.stringify(variants.map(v => ({
                _id:       v._id,
                size:      v.size,
                colorCode: v.color.code,
                colorName: v.color.name,
                stock:     v.stock,
                price:     v.price,
                images:    v.images.map(i => i.url),
                isDefault: v.isDefault,
              })));
            %>
            <% variants.filter(v => v.color.code === selectedVariant.color.code).forEach(v => { %>
              <button
                type="button"
                class="pd-size <%= v._id.toString() === selectedVariant._id.toString() ? 'pd-size--active' : '' %> <%= v.stock <= 0 ? 'pd-size--disabled' : '' %>"
                data-variant-id="<%= v._id %>"
              >
                <%= v.size %>
              </button>
            <% }) %>
          </div>
        </div>

        <!-- Quantity -->
        <div class="pd-qty-wrap">
          <div class="pd-qty">
            <button type="button" id="minusBtn" class="pd-qty-btn" disabled>−</button>
            <input type="number" id="qtyInput" class="pd-qty-input" value="1" min="1" max="5" readonly />
            <button type="button" id="plusBtn" class="pd-qty-btn">+</button>
          </div>
          <p class="pd-qty-note">Max 5 per order</p>
        </div>

        <!-- Error -->
        <div class="pd-error" id="errorBox"></div>

        <!-- Actions -->
        <div class="pd-actions">

          <form action="/user/cart/add" method="POST" class="pd-action-form" id="cartForm">
            <input type="hidden" name="variantId" id="cartVariantId" value="<%= selectedVariant._id %>" />
            <input type="hidden" name="quantity"  id="cartQty"       value="1" />
            <button
              type="submit"
              class="pd-cart-btn"
              id="cartBtn"
              <%= selectedVariant.stock <= 0 ? 'disabled' : '' %>
            >Add to Cart</button>
          </form>

          <form action="/user/checkout/buy-now" method="POST" class="pd-action-form" id="buyForm">
            <input type="hidden" name="variantId" id="buyVariantId" value="<%= selectedVariant._id %>" />
            <input type="hidden" name="quantity"  id="buyQty"       value="1" />
            <button
              type="submit"
              class="pd-buy-btn"
              id="buyBtn"
              <%= selectedVariant.stock <= 0 ? 'disabled' : '' %>
            >Buy Now</button>
          </form>
<form
  action="/user/wishlist/add"
  method="POST"
  class="wishlist-form"
>

  <input
    type="hidden"
    name="productId"
    value="<%= product._id %>"
  />

  <button
    type="submit"
    class="pd-wishlist-btn <%= isWishlisted ? 'pd-wishlist-btn--active' : '' %>"
    aria-label="Add to wishlist"
  >

    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="<%= isWishlisted ? 'currentColor' : 'none' %>"
      stroke="currentColor"
      stroke-width="1.8"
    >
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>

  </button>

</form>


        </div>

        <!-- Accordion -->
        <div class="pd-accordion">

          <details open>
            <summary>Fit &amp; Material</summary>
            <div class="pd-accordion-content">
              <ul>
                <li>Fit: <%= product.fit %></li>
                <li>Material: <%= product.material %></li>
              </ul>
            </div>
          </details>

          <details>
            <summary>Wash &amp; Care</summary>
            <div class="pd-accordion-content">
              <p><%= product.washCare %></p>
            </div>
          </details>

        </div>
      </div>
      
    </section>

    <!-- RELATED PRODUCTS -->
    <% if (relatedProducts && relatedProducts.length > 0) { %>
      <section class="pd-related">
        <div class="pd-related-head">
          <h2>You May Also Like</h2>
        </div>
        <div class="pd-related-grid">
          <% relatedProducts.forEach(item => { %>
            <a href="/user/product/<%= item._id %>" class="pd-related-card">
              <form class="related-wishlist-form">
              <input
                type="hidden"
                name="productId"
                value="<%= item._id %>"
              />

              <button
                type="submit"
                class="pd-related-wish <%= item.isWishlisted ? 'pd-related-wish--active' : '' %>"
                aria-label="Wishlist"
              >

                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="<%= item.isWishlisted ? 'currentColor' : 'none' %>"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>

              </button>

            </form>
              <div class="pd-related-image-wrap">
                <img src="<%= item.defaultImage %>" alt="<%= item.name %>" class="pd-related-image" loading="lazy" />
              </div>
              <div class="pd-related-info">
                <h4 class="pd-related-name"><%= item.name %></h4>
                <p class="pd-related-price">₹<%= item.basePrice.toLocaleString('en-IN') %></p>
              </div>
            </a>
          <% }) %>
        </div>
      </section>
    <% } %>

<!-- REVIEWS -->
<section class="pd-reviews">

  <div class="pd-reviews-top">

    <div class="pd-reviews-summary">

      <div class="pd-reviews-rating-wrap">
        <h2 class="pd-reviews-rating">4.8</h2>

        <div class="pd-reviews-meta">
          <div class="pd-reviews-stars">
            ★★★★★
          </div>

          <p class="pd-reviews-count">
            Based on 124 reviews
          </p>
        </div>
      </div>

    </div>

    <button class="pd-review-btn">
      Write a Review
    </button>

  </div>

  <div class="pd-reviews-divider"></div>

  <div class="pd-reviews-grid">

    <div class="pd-review-card">
      <div class="pd-review-card-top">
        <div>
          <h4 class="pd-review-name">Alex M.</h4>

          <div class="pd-review-stars-sm">
            ★★★★★
          </div>
        </div>

        <span class="pd-review-time">
          2 days ago
        </span>
      </div>

      <p class="pd-review-text">
        The fabric quality is outstanding for the price.
        It's soft but substantial. The fit is exactly as described —
        relaxed but not sloppy.
      </p>
    </div>

    <div class="pd-review-card">
      <div class="pd-review-card-top">
        <div>
          <h4 class="pd-review-name">Jordan K.</h4>

          <div class="pd-review-stars-sm">
            ★★★★☆
          </div>
        </div>

        <span class="pd-review-time">
          1 week ago
        </span>
      </div>

      <p class="pd-review-text">
        I bought the Cream and Olive colors.
        They look even better in person.
        The organic cotton feels great against the skin.
        Will buy more!
      </p>
    </div>

    <div class="pd-review-card">
      <div class="pd-review-card-top">
        <div>
          <h4 class="pd-review-name">Taylor R.</h4>

          <div class="pd-review-stars-sm">
            ★★★★☆
          </div>
        </div>

        <span class="pd-review-time">
          2 weeks ago
        </span>
      </div>

      <p class="pd-review-text">
        Love the sustainability aspect.
        The quality is top notch.
        It runs a tiny bit larger than I expected,
        but I like the oversized look anyway.
      </p>
    </div>

  </div>

  <div class="pd-reviews-footer">
    <button class="pd-view-reviews-btn">
      View All Reviews
    </button>
  </div>

</section>

  </main>

  <%- include('../partials/user-scripts') %>
  <script>
    window.__VARIANTS__ = <%- variantsJson %>;
    window.__SELECTED_ID__ = '<%= selectedVariant._id %>';
  </script>
  <script src="/js/user/productDetail.js"></script>

</body>
</html>
