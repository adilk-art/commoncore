<!DOCTYPE html>
<html lang="en">
<head>
  <title>commoncore — Common For All</title>
  <%- include('../partials/user-head') %>
  <link rel="stylesheet" href="/css/user/home.css" />
</head>
<body>

  <%- include('../partials/user-header') %>

  <main class="home-page">

    <!-- ── HERO ── -->
    <section class="hero">

      <div class="hero-left">
        <span class="hero-tag">COMMONCORE® 2026 COLLECTION</span>
        <h1 class="hero-title">
          Quiet<br>
          Luxury<br>
          <em>for Every</em><br>
          Day.
        </h1>
        <p class="hero-body">
          Elevated essentials built around clean silhouettes,
          premium fabrics, and the kind of simplicity that
          never goes out of style.
        </p>
        <div class="hero-actions">
          <a href="/user/shop" class="btn-dark">
            Shop Now
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/user/shop" class="btn-ghost">
            Explore Collection
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="hero-right">

        <!-- Floating badges -->
        <div class="badge-float badge-float--tl">
          <span class="badge-label">New Drop</span>
          <span class="badge-val">SS 2026</span>
        </div>
        <div class="badge-float badge-float--br">
          <span class="badge-label">Ships in</span>
          <span class="badge-val">2–4 days</span>
        </div>

        <!-- Hero image — swap src with your actual image -->
        <div class="hero-img-wrap">
          <div class="hero-figure">
            <img
              src="/images/hero.png"
              alt="2026 Collection"
              class="hero-figure-img"
              onerror="this.style.display='none'"
            />
          </div>
        </div>

      </div>
    </section>

