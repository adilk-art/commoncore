    <!-- ── CATEGORIES ── -->
   <section class="section">

  <div class="section-header">
    <span class="section-title">Shop by Category</span>

    <a href="/user/shop" class="section-link">
      View all →
    </a>
  </div>

  <div class="cat-grid">

    <a
      href="/user/shop?search=&sort=&minPrice=&maxPrice=&category=6a0319106e95d204811a5784&page=1"
      class="cat-card cat-card--large cat-card--warm"
    >
      <div class="cat-info">
        <span class="cat-eyebrow">ESSENTIALS</span>

        <div class="cat-name">
          T-Shirts
        </div>

        <div class="cat-sub">
          Clean basics for daily rotation
        </div>
      </div>

      <img
        src="/images/tshirts.png"
        alt="T-Shirts"
        class="cat-img"
      />
    </a>


    <div class="cat-stack">

      <a
  href="/user/shop?search=&sort=&minPrice=&maxPrice=&category=6a0319066e95d204811a577c&page=1"
  class="cat-card cat-card--cool"
>
        <div class="cat-info">
          <span class="cat-eyebrow">DENIM</span>

          <div class="cat-name">
            Jeans
          </div>
        </div>

        <img
          src="/images/jeans.png"
          alt="Jeans"
          class="cat-img"
        />
      </a>


      <a
  href="/user/shop?search=&sort=&minPrice=&maxPrice=&category=6a0319426e95d204811a578e&page=1"
  class="cat-card cat-card--muted"
>
        <div class="cat-info">
          <span class="cat-eyebrow">LAYERS</span>

          <div class="cat-name">
            Hoodies
          </div>
        </div>

        <img
          src="/images/hoodies.png"
          alt="Hoodies"
          class="cat-img"
        />
      </a>

    </div>


    <a
      href="/user/shop"
      class="cat-card cat-card--large cat-card--sage"
    >
      <div class="cat-info">
        <span class="cat-eyebrow">ALL STYLES</span>

        <div class="cat-name">
          Full<br>Collection
        </div>

        <div class="cat-sub" style="margin-top:14px;">
          Browse everything →
        </div>
      </div>
    </a>

  </div>

</section>

    <!-- ── FEATURED PRODUCTS ── -->
  

    <!-- ── FEATURES ── -->
    <section class="features">

      <div class="feat">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <h3>Premium Materials</h3>
        <p>Carefully selected fabrics with elevated comfort and lasting durability.</p>
      </div>

      <div class="feat">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <polyline points="1 4 1 10 7 10"/>
            <path d="M3.51 15a9 9 0 1 0 .49-3.5"/>
          </svg>
        </div>
        <h3>Easy Returns</h3>
        <p>Smooth 30-day returns and hassle-free exchanges on every order.</p>
      </div>

      <div class="feat">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="1" y="3" width="15" height="13"/>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
        </div>
        <h3>Fast Shipping</h3>
        <p>Reliable delivery across India in 2–4 business days.</p>
      </div>

    </section>

  </main>

