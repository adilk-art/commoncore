  <title>Account Blocked</title>
  <link rel="stylesheet" href="/css/user/blocked.css">
</head>
<body>

  <div class="blocked-wrapper">

    <div class="blocked-card">

      <div class="icon">🚫</div>

      <h1>Account Blocked</h1>

      <p>
        Your account access has been temporarily paused.
