<!DOCTYPE html>
<html>
<head>
  <title>Edit Profile</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/user/style.css">
  <link rel="stylesheet" href="/css/user/otp-modal.css">
  <link rel="stylesheet" href="/css/user/editProfile.css">
  <link rel="stylesheet" href="/css/user/global.css">
</head>
<body>

<%- include("../partials/header") %>

<div class="account-container">

  <%- include("../partials/sidebar", { active: "profile" }) %>

  <div class="main-content">

    <h2>Edit Profile</h2>
    <div class="edit-container">


      <div class="edit-card">

        <!-- FORM -->
        <form action="/user/profile/edit" method="POST" enctype="multipart/form-data">

          <!-- PROFILE IMAGE -->
          <div class="image-section">

          <img src="<%= user.profileImage %>" id="previewImg" class="profile-img">

          <label for="profileImageInput" class="change-btn">
            Change Photo
          </label>

          <input type="file" name="profileImage" id="profileImageInput" hidden>

        </div>

          <!-- NAME -->
          <div class="form-group">
            <label>Name</label>
            <input type="text" name="name" id="name" value="<%= user.name %>">
            <p class="error-msg" id="nameError"></p>
          </div>

          <!-- EMAIL -->
          <div class="form-group">
            <label>Email</label>

            <div class="email-wrapper">
              <input type="text" value="<%= user.email %>" readonly class="email-input">

              <span class="change-email-btn" onclick="openEmailModal()">
                Change
              </span>
            </div>
          </div>

          <!-- PHONE -->
          <div class="form-group">
            <label>Phone</label>
            <input type="text" name="phone" id="phone" value="<%= user.phone || '' %>">
            <p class="error-msg" id="phoneError"></p>
          </div>

          <% if (typeof error !== "undefined") { %>
            <p class="error-msg" style="display:block;"><%= error %></p>
          <% } %>

          <div class="form-actions">
            <button type="submit" class="btn submit-btn">Save Changes</button>
            <a href="/user/profile" class="btn cancel-btn">Cancel</a>
            </div>

        </form>

      </div>

    </div>

  </div>

</div>

<!-- MODAL -->
<div id="emailModal" class="email-modal">
  <div class="modal-content">

    <span class="close" onclick="closeEmailModal()">&times;</span>

    <!-- STEP 1: PASSWORD -->
    <div id="step1">
      <h3>Confirm Password</h3>

    <div class="input-wrapper">
      <input type="password" id="confirmPassword" placeholder="Enter current password">

      <span class="eye-toggle-btn" id="confirmPassEye">
        <i class="fa-solid fa-eye"></i>
      </span>
    </div>
      <p id="passwordError" class="error-msg"></p>

      <button type="button" onclick="verifyPasswordStep()">Continue</button>
    </div>

    <!-- STEP 2: EMAIL -->
    <div id="step2" style="display:none;">
      <h3>Enter New Email</h3>

      <input type="email" id="newEmail" placeholder="Enter new email">
      <p id="emailError" class="error-msg"></p>

      <button type="button" onclick="sendOtp()">Send OTP</button>
    </div>

  </div>
</div>
<%- include("../partials/otp-modal") %>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/user/otpModal.js"></script>
<script src="/js/user/editProfile.js"></script>
<script src="/js/user/editProfileValidation.js"></script>
</body>
</html>