<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password</title>
  <link rel="stylesheet" href="/css/user/reset-password.css">
</head>
<body>
  <div class="container">
    <div class="card">
      <h2>Reset Password</h2>
      <p>Enter your new password</p>

      <form action="/user/reset-password" method="POST" id="resetForm">

        <!-- email from session passed by controller -->
        <input type="hidden" name="email" value="<%= email %>"/>

        <div class="input-group">
          <label>New Password</label>
          <input type="password" name="password" id="password" placeholder="••••••••"/>
        </div>


        <div class="input-group">
          <label>Confirm Password</label>
          <input type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••••"/>
        </div>

        <% if(error) { %>
          <span class="error-msg" id="errorMsg" style="display:block"><%= error %></span>
        <% } else { %>
          <span class="error-msg" id="errorMsg" style="display:none"></span>
        <% } %>

        <button type="submit">Reset Password</button>
      </form>
    </div>
  </div>
  <script src="/js/user/resetPassword.js"></script>
</body>
</html>