<!DOCTYPE html>
<html lang="en">
<head>
  <title>Page Not Found — Commoncore</title>

  <%- include('../partials/user-head') %>

  <link
    rel="stylesheet"
    href="/css/error/404.css"
  />
</head>
<body>


  <main class="sp-page">

    <section class="sp-card">

      <span class="sp-tag">
        ERROR 404
      </span>

      <h1 class="sp-code">
        404
      </h1>

      <h2 class="sp-title">
        Page Not<br>
        Found.
      </h2>

      <p class="sp-body">
        The page you are looking for does not exist,
        may have been removed, or is currently unavailable.
      </p>

      <div class="sp-actions">

        <a
          href="/user/shop"
          class="sp-btn sp-btn--dark"
        >
          Continue Shopping

          <svg
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <a
          href="/"
          class="sp-btn sp-btn--ghost"
        >
          Back to Home
        </a>

      </div>

    </section>

  </main>

</body>
</html>