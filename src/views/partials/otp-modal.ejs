<div class="otp-modal" id="otpModal">
  <div class="otp-box">

    <!-- NORMAL OTP CONTENT -->
    <div id="otpContent">

      <span class="otp-close" onclick="closeOtpModal()">&times;</span>

      <h2>Verify OTP</h2>
      <p id="otpPurpose">Enter the code sent to your email</p>

      <span id="otpError" class="otp-error"></span>

      <div class="otp-inputs">
        <input type="text" maxlength="1" inputmode="numeric" />
        <input type="text" maxlength="1" inputmode="numeric" />
        <input type="text" maxlength="1" inputmode="numeric" />
        <input type="text" maxlength="1" inputmode="numeric" />
        <input type="text" maxlength="1" inputmode="numeric" />
        <input type="text" maxlength="1" inputmode="numeric" />
      </div>

      <button class="verify-btn" onclick="verifyOtp()">Verify</button>

      <div class="otp-footer">
        <span id="timer">01:00</span>
        <button id="resendBtn" disabled onclick="resendOtp()">Resend</button>
      </div>

    </div>

    <!-- SUCCESS STATE -->
    <div id="otpSuccess" style="display:none;">
      <div class="success-check">✔</div>
      <p id="successContent"></p>
    </div>

  </div>
</div>